#!/bin/bash
set -euo pipefail

dirs=(
  "$HOME"/src/dotfiles
  "$HOME"/.claude
  "$HOME"/src/shellsafety
  "$HOME"/src/statusline
)

for dir in "${dirs[@]}"; do
  echo "upd: pulling and pushing $dir..."
  git -C "$dir" pull
  git -C "$dir" push
done

echo "upd: installing shellsafety..."
( 
  cd "$HOME"/src/shellsafety
  cabal install --overwrite-policy=always
)

echo "upd: installing statusline..."
( 
  cd "$HOME"/src/statusline
  cargo install --path .
)

