#!/bin/bash
set -euo pipefail

dirs=(
  "$HOME"/src/dotfiles
  "$HOME"/.claude
  "$HOME"/src/shellsafety
  "$HOME"/src/statusline
)

for dir in "${dirs[@]}"; do
  echo "upd: pulling and pushing $dir..."
  # Check for modified files
  if [[ -n $(git -C "$dir" status --porcelain) ]]; then
    echo "upd: warning: Uncommitted changes in $dir. Please commit or stash them before pushing."
    git -C "$dir" status
    continue
  fi
  git -C "$dir" pull
  git -C "$dir" push
done

echo "upd: installing shellsafety..."
( 
  cd "$HOME"/src/shellsafety
  cabal install --overwrite-policy=always
)

echo "upd: installing statusline..."
( 
  cd "$HOME"/src/statusline
  cargo install --path .
)

